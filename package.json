{
  "name": "@apiglot/solidjs",
  "version": "0.0.1",
  "description": "SolidJS library with tools and artifacts to help you internationalize your SolidJS applications.",
  "license": "MIT",
  "author": "Apiglot",
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apiglot/solidjs.git"
  },
  "homepage": "https://github.com/apiglot/solidjs#readme",
  "bugs": {
    "url": "https://github.com/apiglot/solidjs/issues"
  },
  "files": [
    "dist"
  ],
  "private": false,
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index/index.js",
  "module": "./dist/index/index.js",
  "types": "./dist/index/index.d.ts",
  "browser": {},
  "exports": {
    ".": {
      "development": {
        "import": {
          "types": "./dist/index/index.d.ts",
          "default": "./dist/index/dev.js"
        }
      },
      "import": {
        "types": "./dist/index/index.d.ts",
        "default": "./dist/index/index.js"
      }
    },
    "./i18next": {
      "solid": {
        "development": "./dist/i18next/dev.jsx",
        "import": "./dist/i18next/index.jsx"
      },
      "development": {
        "import": {
          "types": "./dist/i18next/index.d.ts",
          "default": "./dist/i18next/dev.js"
        }
      },
      "import": {
        "types": "./dist/i18next/index.d.ts",
        "default": "./dist/i18next/index.js"
      }
    }
  },
  "typesVersions": {
    "*": {
      "i18next": [
        "./dist/i18next/index.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "vite serve dev",
    "build": "tsup",
    "test": "concurrently pnpm:test:*",
    "test:client": "vitest",
    "test:ssr": "pnpm run test:client --mode ssr",
    "prepublishOnly": "pnpm build",
    "format": "prettier --ignore-path .gitignore -w \"src/**/*.{js,ts,json,css,tsx,jsx}\" \"dev/**/*.{js,ts,json,css,tsx,jsx}\"",
    "lint": "concurrently pnpm:lint:*",
    "lint:code": "eslint --ignore-path .gitignore --max-warnings 0 src/**/*.{js,ts,tsx,jsx}",
    "lint:types": "tsc --noEmit",
    "update-deps": "pnpm up -Li"
  },
  "peerDependencies": {
    "solid-js": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.3",
    "esbuild-plugin-solid": "^0.6.0",
    "eslint": "^8.56.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-no-only-tests": "^3.1.0",
    "jsdom": "^24.0.0",
    "prettier": "3.0.0",
    "solid-js": "^1.8.17",
    "tsup": "^8.0.2",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-solid": "^2.10.2",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "solid"
  ],
  "packageManager": "pnpm@9.1.1",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "i18next": "^25.7.4",
    "i18next-http-backend": "^3.0.2"
  }
}
